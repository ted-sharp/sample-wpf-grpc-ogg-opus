<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <LangVersion>latest</LangVersion>
    <RootNamespace>Sample.Client.Unary</RootNamespace>
    <AssemblyName>Sample.Client.Unary</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- WebRtcVadSharp は WebRtcVad.dll (ネイティブ) を要求する。
         AnyCPU だと WebRtcVadSharp.targets が警告を出して既定 x64 を使うので、
         明示的に x64 を指定して bin/ にネイティブ DLL を確実に配置する。 -->
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MagicOnion.Client" Version="4.5.2" />
    <PackageReference Include="Grpc.Core" Version="2.46.6" />
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="Concentus" Version="1.1.7" />
    <PackageReference Include="Concentus.OggFile" Version="1.0.4" />
    <!-- ネイティブ DLL を当 exe の bin にコピーさせるため Shared 経由でなく直接参照する。
         Sample.Shared 側にも同じ参照があるのは VadGate.cs のコンパイル用。 -->
    <PackageReference Include="WebRtcVadSharp" Version="1.3.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Sample.Shared\Sample.Shared.csproj" />
  </ItemGroup>

</Project>
